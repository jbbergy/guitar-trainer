{
  "appId": "com.guitare-trainer.app",
  "productName": "Guitare Trainer",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "category": "public.app-category.education",
    "icon": "public/icon.png",
    "extendInfo": {
      "NSMicrophoneUsageDescription": "Guitare Trainer needs microphone access to detect chords you play."
    }
  },
  "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "icon": "public/icon.png"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Education",
    "icon": "public/icon.png"
  }
}